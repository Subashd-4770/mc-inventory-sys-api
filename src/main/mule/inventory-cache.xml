                <logger level="ERROR"
                        message='#["Unexpected Error : " ++ error.description]'/>

                <raise-error
                        type="APP:INTERNAL_SERVER_ERROR"
                        description="Unexpected Error Occurred"/>

            </on-error-propagate>

        </error-handler>

    </try>

</ee:cache>
			</otherwise>

</choice>
		<choice doc:name="Check Cache Availability" doc:id="c90de8c8-46e2-494c-a633-aa5344aa28b8" >
