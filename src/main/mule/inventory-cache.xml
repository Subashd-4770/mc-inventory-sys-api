    <try doc:name="Retrieve Cache">

        <db:select doc:name="Fetch Product From Inventory" doc:id="49a0aac8-883a-4529-bd23-3cbe3e617e17" config-ref="Database_Config">
				<db:sql><![CDATA[SELECT * FROM inventory
WHERE product_id = :product_id]]></db:sql>
				<db:input-parameters><![CDATA[#[product_id: vars.product]]]></db:input-parameters>
			</db:select>

        <error-handler>

            <on-error-propagate type="DB:CONNECTIVITY">

                <logger level="ERROR" message='#["Cache DB Connectivity Error : " ++ error.description]' />

            </on-error-propagate>

            <on-error-propagate type="DB:QUERY_EXECUTION">

                <logger level="ERROR" message='#["Cache Query Failed : " ++ error.description]' />

            </on-error-propagate>
            <on-error-propagate type="ANY"
