    <flow name="get:\getProducts:mc-inventory-sys-spec-config">

    <logger level="INFO"
            doc:name="Flow Started"
            message='#["Started To Get Products"]'/>

    <try doc:name="Fetch Products From Database">

        <db:select config-ref="Database_Config"
                   doc:name="Fetch All Products">

            <db:sql><![CDATA[
SELECT *
from inventory]]></db:sql>

        </db:select>

        <choice doc:name="Check Products Available">

            <when expression="#[sizeOf(payload) &gt; 0]">

                <logger level="INFO"
                        message='#["Products Found : " ++ sizeOf(payload)]'/>

                <ee:transform doc:name="Prepare Success Response">
                    <ee:message>
                        <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
    success: true,
    message: "Products Retrieved Successfully",
    totalRecords: sizeOf(payload),
    data: payload
}
]]></ee:set-payload>
                    </ee:message>
                </ee:transform>

            </when>

            <otherwise>

                <logger level="INFO"
                        message='#["Inventory Table Is Empty"]'/>

                <ee:transform doc:name="Prepare Empty Response">
                    <ee:message>
                        <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
    success: true,
    message: "No Products Found",
    totalRecords: 0,
    data: []
}
]]></ee:set-payload>
                    </ee:message>
                </ee:transform>

            </otherwise>

        </choice>

        <error-handler>

            <!-- Database Connectivity -->
            <on-error-propagate type="DB:CONNECTIVITY"
                                logException="true">

                <logger level="ERROR"
                        message='#["Database Connectivity Error : " ++ error.description]'/>

                <set-variable variableName="httpStatus"
                              value="503"/>

                <ee:transform doc:name="DB Connectivity Response">
                    <ee:message>
                        <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
    success: false,
    status: 503,
    message: "Unable to connect to Database",
    error: error.description,
    timestamp: now()
}
]]></ee:set-payload>
                    </ee:message>
                </ee:transform>

            </on-error-propagate>

            <!-- Query Execution Error -->
            <on-error-propagate type="DB:QUERY_EXECUTION"
                                logException="true">

                <logger level="ERROR"
                        message='#["Query Execution Error : " ++ error.description]'/>

                <set-variable variableName="httpStatus"
                              value="500"/>

                <ee:transform doc:name="Query Error Response">
                    <ee:message>
                        <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
    success: false,
    status: 500,
    message: "Database Query Failed",
    error: error.description,
    timestamp: now()
}
]]></ee:set-payload>
                    </ee:message>
                </ee:transform>

            </on-error-propagate>

        </error-handler>

    </try>

    <logger level="INFO"
            message='#["Flow Completed Successfully"]'/>

    <error-handler>

        <!-- Handles all unexpected errors in the flow -->
        <on-error-propagate type="ANY"
                            logException="true">

            <logger level="ERROR"
                    message='#["Unexpected Error : " ++ error.description]'/>

            <set-variable variableName="httpStatus"
                          value="500"/>

            <ee:transform doc:name="Internal Server Error">
                <ee:message>
                    <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
    success: false,
    status: 500,
    message: "Internal Server Error",
    errorDescription: error.description,
    timestamp: now()
}
]]></ee:set-payload>
                </ee:message>
            </ee:transform>

        </on-error-propagate>

    </error-handler>

</flow>
    <flow name="post:\saveInventory:application\json:mc-inventory-sys-spec-config">

    <logger level="INFO"
            doc:name="Flow Started"
            message='#["Inventory Insert Flow Started"]'/>

    <ee:transform doc:name="Transform Inventory Payload">
        <ee:message>
            <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
payload
]]></ee:set-payload>
        </ee:message>
    </ee:transform>

    <set-variable variableName="inventory"
                  value="#[payload]"
                  doc:name="Store Inventory Payload"/>

    <logger level="INFO"
            message='#["Payload = " ++ write(payload,"application/json")]'/>

    <choice doc:name="Validate Request">

        <when expression="#[isEmpty(payload.product_id)]">
            <raise-error type="APP:INVALID_REQUEST"
                         description="Product Id is mandatory"/>
        </when>

        <when expression="#[isEmpty(payload.product_name)]">
            <raise-error type="APP:INVALID_REQUEST"
                         description="Product Name is mandatory"/>
        </when>

        <when expression="#[payload.quantity == null]">
            <raise-error type="APP:INVALID_REQUEST"
                         description="Quantity is mandatory"/>
        </when>

        <when expression="#[payload.quantity &lt; 0]">
            <raise-error type="APP:INVALID_REQUEST"
                         description="Quantity cannot be negative"/>
        </when>
		<otherwise >
		
		<until-successful maxRetries="5"
                      millisBetweenRetries="6000"
                      doc:name="Retry Insert">

        <try doc:name="Insert Inventory">

            <db:insert config-ref="Database_Config"
                       doc:name="Insert Inventory Record">

                <db:sql><![CDATA[
INSERT INTO inventory
(
product_id,
product_name,
quantity
)
VALUES
(
:product_id,
:product_name,
:quantity
)
]]></db:sql>

                <db:input-parameters><![CDATA[#[{
    product_id: payload.product_id,
    product_name: payload.product_name,
    quantity: payload.quantity
}]]]></db:input-parameters>

            </db:insert>

            <error-handler>
            
                <on-error-propagate type="DB:CONNECTIVITY"
                                    logException="true">

                    <logger level="ERROR"
                            message='#["Database Connectivity Error : " ++ error.description]'/>

                </on-error-propagate>

            </error-handler>

        </try>

    </until-successful>
		</otherwise>
    </choice>

    

    <ee:transform doc:name="Prepare Success Response">
        <ee:message>
            <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
    success : true,
    message : "Inventory inserted successfully",
    data : vars.inventory
}
]]></ee:set-payload>
        </ee:message>
    </ee:transform>

    <logger level="INFO"
            message='#["Inventory inserted successfully"]'/>

    <error-handler>

        <on-error-propagate type="APP:INVALID_REQUEST"
                            logException="true">

            <set-variable variableName="httpStatus"
                          value="400"/>

            <ee:transform doc:name="Validation Error">
                <ee:message>
                    <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
    success:false,
    status:400,
    message:error.description,
    timestamp:now()
}
]]></ee:set-payload>
                </ee:message>
            </ee:transform>

        </on-error-propagate>

        <on-error-propagate type="DB:*"
                            logException="true">

            <set-variable variableName="httpStatus"
                          value="503"/>

            <ee:transform doc:name="Database Error">
                <ee:message>
                    <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
    success:false,
    status:503,
    message:"Database unavailable",
    error:error.description,
    timestamp:now()
}
]]></ee:set-payload>
                </ee:message>
            </ee:transform>

        </on-error-propagate>

        <on-error-propagate type="ANY"
                            logException="true">

            <set-variable variableName="httpStatus"
                          value="500"/>

            <ee:transform doc:name="Internal Server Error">
                <ee:message>
                    <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
    success:false,
    status:500,
    message:"Internal Server Error",
    error:error.description,
    timestamp:now()
}
]]></ee:set-payload>
                </ee:message>
            </ee:transform>

        </on-error-propagate>

    </error-handler>

</flow>
</mule>
