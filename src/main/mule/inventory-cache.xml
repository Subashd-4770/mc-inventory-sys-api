            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
	status : true,
    message : "Data Found In Cache",
    data : payload
}]]></ee:set-payload>
            </ee:message>
        </ee:transform>
			</when>
			<otherwise >
				<logger level="INFO" doc:name="Logger" doc:id="6f8e2418-29c9-4445-a17c-2295b68e6a76" message='#[vars.product]'/>
				<try doc:name="Salesforce Query">

    <salesforce:query doc:name="Retrieve Product From Salesforce" doc:id="09eb5155-32b9-4b47-9d1e-f7f07e2e26b8" config-ref="Salesforce_Config" >
					<salesforce:salesforce-query ><![CDATA[select product_id__c,product_name__c,quantity__c from Product2
where product_id__c = :product_id]]></salesforce:salesforce-query>
					<salesforce:parameters ><![CDATA[#[{
    product_id : vars.product
}]]]></salesforce:parameters>
						<salesforce:headers />
				</salesforce:query>
    <logger level="INFO" doc:name="Logger" doc:id="f4666283-33ff-4943-a2c8-7135dd3fd8ac" message='#[write(payload,"application/json")]'/>
					<error-handler>

        <on-error-propagate type="SALESFORCE:CONNECTIVITY">

            <logger level="ERROR"
                    message='#["Salesforce Connectivity Error"]'/>

        </on-error-propagate>

        <on-error-propagate type="ANY">

            <logger level="ERROR"
                    message='#["Salesforce Error : " ++ error.description]'/>

        </on-error-propagate>

    </error-handler>

</try>
				<choice doc:name="Check Salesforce Result" doc:id="908539f2-44ca-4f48-97ce-a9cf56e0d7c4" >
					<when expression="#[sizeOf(payload) &gt; 0]">
						<logger level="INFO" doc:name="Logger" doc:id="ecd25147-f4a5-4902-b83f-dd3686f88e7a" message='#["Data Insert in Cache"]'/>
						<set-variable value="#[{&#10;    product_id : payload[0].product_id__c as Number,&#10;    product_name : payload[0].product_name__c,&#10;    quantity : payload[0].quantity__c as Number&#10;}]" doc:name="Store Salesforce Product" doc:id="fccc1c5a-fc94-4ac5-878b-1767e0833b97" variableName="salesforceproduct" />
						<logger level="INFO" doc:name="Logger" doc:id="ab74e980-8e72-481b-bec2-822669c7a52b" message="#[vars.salesforceproduct]"/>
						<logger level="INFO" doc:name="Logger" doc:id="e293d512-60a1-41a3-8aa3-b82fb395f57f" message="#[typeOf(vars.salesforceproduct.product_id__c) ++&#10;typeOf(vars.salesforceproduct.quantity__c)]"/>
						<try doc:name="Insert Into Cache">

    <db:insert doc:name="Store Product In Cache" doc:id="2617236e-3147-4591-98b6-75e11938696c" config-ref="Database_Config">
								<db:sql ><![CDATA[INSERT INTO inventory
(
product_id,
product_name,
quantity
)
VALUES
(
	:product_id,
	:product_name,
	:quantity
)	]]></db:sql>
								<db:input-parameters ><![CDATA[#[vars.salesforceproduct]]]></db:input-parameters>
							</db:insert>
							<error-handler>

        <on-error-propagate type="DB:CONNECTIVITY">

            <logger level="ERROR"
                    message='#["Database Connection Failed"]'/>

        </on-error-propagate>

    </error-handler>

</try>
						<ee:transform doc:name="Prepare Cache Insert Response" doc:id="72eaacf6-830a-4832-8819-ae2aefcc7cda">
			<ee:message>
				<ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
	status : true,
	message : "Inserted in Cache Table",
	data : vars.salesforceproduct
}]]></ee:set-payload>
			</ee:message>
		</ee:transform>
					</when>
					<otherwise >
						<logger level="INFO" doc:name="Logger" doc:id="17dbb1b0-8b52-4850-9325-ea63247fab86" message='#["Product Not Found In Salesforce"]'/>
						<ee:transform doc:name="Prepare Product Not Found Response" doc:id="e8b74d63-8ad2-4f4a-9f51-92f9d6914dd1" >
							<ee:message >
								<ee:set-payload ><![CDATA[%dw 2.0
output application/json
---
{
	status : false,
    message : "Data Not Found In SalesForce and Cache",
    data : payload
}]]></ee:set-payload>
							</ee:message>
						</ee:transform>
					</otherwise>
				</choice>
			</otherwise>
		</choice>
		<logger level="INFO" doc:name="Logger" doc:id="5bb2c564-dda3-484f-9f7c-6c4608ccb8f2" message='#["Cache Flow Completed"]'/>
		<error-handler>

    <on-error-propagate type="APP:INVALID_REQUEST">

        <set-variable variableName="httpStatus"
                      value="400"/>

        <ee:transform>
            <ee:message>
                <ee:set-payload><![CDATA[
