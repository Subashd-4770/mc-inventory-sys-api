    <flow name="get:\getCacheById:mc-inventory-sys-spec-config">
        <logger level="INFO" doc:name="Logger" doc:id="55968113-0355-4f76-bcc8-8484dd3e9482" message='#["Cache Flow Started"]'/>
		<set-variable value="#[attributes.queryParams.id]" doc:name="Store Product Id" doc:id="92986b92-2ea2-4bde-ba46-c602c118fd17" variableName="product"/>
